<Window x:Class="KTV.ControlPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KTV Control Panel" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen" Background="#121212">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Pane: AI Agent & Queue -->
        <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="10" Padding="15" Margin="0,0,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <TextBlock Text="AI 點歌助理" Foreground="#BB86FC" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                <!-- Chat Log / Search Result -->
                <ListBox Grid.Row="1" Name="ChatHistory" Background="Transparent" BorderThickness="0" Foreground="White" Margin="0,0,0,10">
                </ListBox>

                <!-- Input Area -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Name="ChatInput" Height="35" Background="#2C2C2C" Foreground="White" BorderThickness="0" Padding="5" VerticalContentAlignment="Center"/>
                    <Button Grid.Column="1" Content="送出" Click="SendChat_Click" Width="60" Margin="5,0,0,0" Background="#BB86FC" Foreground="Black" FontWeight="Bold" BorderThickness="0"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Right Pane: Playlist & Player Control -->
        <Grid Grid.Column="1" Margin="10,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Song List Grid -->
            <Border Background="#1E1E1E" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="歌單列表 (SQLite)" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                    <DataGrid Grid.Row="1" Name="SongsDataGrid" Background="Transparent" Foreground="White" RowBackground="#2C2C2C" AlternatingRowBackground="#1E1E1E" BorderThickness="0" AutoGenerateColumns="False" CanUserAddRows="False">
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Playback Control Bar -->
            <Border Grid.Row="1" Background="#1E1E1E" CornerRadius="10" Padding="15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Playing Song Info -->
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Name="CurrentSongText" Text="當前播放：未播放" Foreground="White" FontSize="16" FontWeight="Bold"/>
                        <TextBlock Name="CurrentArtistText" Text="歌手：--" Foreground="#888888" FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Right: Control Buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="原/伴唱" Click="ToggleVocal_Click" Width="80" Height="40" Margin="5,0,5,0" Background="#03DAC6" Foreground="Black" FontWeight="Bold" BorderThickness="0"/>
                        <Button Content="降 Key" Click="PitchDown_Click" Width="60" Height="40" Margin="5,0,5,0" Background="#CF6679" Foreground="Black" FontWeight="Bold" BorderThickness="0"/>
                        <TextBlock Text="Key: 0" Name="PitchText" Foreground="White" FontSize="16" VerticalAlignment="Center" Margin="5,0,5,0"/>
                        <Button Content="升 Key" Click="PitchUp_Click" Width="60" Height="40" Margin="5,0,5,0" Background="#CF6679" Foreground="Black" FontWeight="Bold" BorderThickness="0"/>
                        <Button Content="下一首" Click="NextSong_Click" Width="80" Height="40" Margin="5,0,5,0" Background="#BB86FC" Foreground="Black" FontWeight="Bold" BorderThickness="0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
