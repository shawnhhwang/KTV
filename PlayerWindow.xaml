<Window x:Class="KTV.PlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="KTV Player Screen" Height="450" Width="800"
        Background="Black" WindowStartupLocation="Manual">
    <Grid>
        <vlc:VideoView x:Name="VlcVideoView" Background="Black" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <TextBlock Text="KTV Playback Screen" Foreground="Gray" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </vlc:VideoView>
    </Grid>
</Window>
